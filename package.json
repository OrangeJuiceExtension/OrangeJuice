{
	"name": "orangejuice",
	"description": "Orange Juice makes HackerNews sweeter",
	"private": true,
	"version": "0.22.46",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"build": "wxt build",
		"build-watch": "chokidar --initial --silent \"src/**/*\" -c \"bun run build\"",
		"build:firefox": "wxt build -b firefox",
		"webext:firefox:lint": "web-ext -w -s .output/firefox-mv2/ lint",
		"icons": "bun run scripts/generate-icons.ts",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox",
		"compile": "tsc --noEmit",
		"postinstall": "wxt prepare",
		"test": "vitest",
		"ci": "CI=true bun run --parallel check test build build:firefox && bun run webext:firefox:lint && bun run clean && CI=true bun run --parallel zip zip:firefox",
		"check": "bun ./node_modules/ultracite/dist/index.js check",
		"fix": "bun ./node_modules/ultracite/dist/index.js fix",
		"prepare": "lefthook install",
		"clean": "rm -rf .output build-docs playwright-report"
	},
	"dependencies": {
		"@wxt-dev/storage": "^1.2.8",
		"beautiful-mermaid": "^1.1.3",
		"comctx": "^1.6.1",
		"fit-textarea": "^3.0.0",
		"hast-util-from-html": "^2.0.3",
		"hast-util-sanitize": "^5.0.2",
		"linkify-html": "^4.3.2",
		"linkifyjs": "^4.3.2",
		"property-information": "^7.1.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^4.2.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/dom": "^10.4.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@wxt-dev/browser": "^0.1.38",
		"@wxt-dev/module-react": "^1.2.2",
		"chokidar-cli": "^3.0.0",
		"globals": "^17.4.0",
		"happy-dom": "^20.8.9",
		"lefthook": "^2.1.4",
		"oxipng": "^1.0.1",
		"playwright": "^1.58.2",
		"postcss": "^8.5.8",
		"postcss-preset-env": "^11.2.0",
		"sharp": "^0.34.5",
		"typescript": "^6.0.2",
		"ultracite": "7.4.2",
		"vitest": "^4.1.2",
		"vitest-localstorage-mock": "^0.1.2",
		"web-ext": "^10.1.0",
		"wxt": "^0.20.20"
	},
	"trustedDependencies": [
		"spawn-sync"
	]
}
